---
import Layout from '../layouts/Layout.astro';
const WA = 'https://wa.me/542235767784';
---
<Layout title="App Taller" description="Sistema de gestión para talleres mecánicos. Órdenes de trabajo, presupuestos con aprobación online y Kanban. Próximamente.">
  <section class="max-w-2xl mx-auto px-4 py-28 text-center">

    <div class="inline-flex items-center gap-2 bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-1.5 rounded-full mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse"></span>
      En desarrollo · Próximamente
    </div>

    <div class="text-6xl mb-6">🔧</div>

    <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
      App <span class="text-red-400">Taller</span>
    </h1>
    <p class="text-xl text-red-400 font-medium mb-4">El cliente aprueba el presupuesto desde el celular en 1 click</p>
    <p class="text-slate-400 text-lg leading-relaxed mb-10">
      Para talleres mecánicos, chapistas, electricistas del automotor y mecánicos independientes.
      Gestioná órdenes de trabajo, presupuestos y el estado de cada vehículo — sin papeles ni llamadas.
    </p>

    <!-- Features preview -->
    <div class="grid grid-cols-2 gap-3 mb-12 text-left">
      {[
        { icon: '📋', text: 'Órdenes de trabajo por vehículo' },
        { icon: '🔗', text: 'Link de aprobación de presupuesto' },
        { icon: '🗂️', text: 'Kanban: en espera, en taller, listo' },
        { icon: '🚗', text: 'Historial por patente' },
        { icon: '📸', text: 'Fotos de fallas adjuntas' },
        { icon: '💰', text: 'Caja y registro de pagos' },
        { icon: '👥', text: 'Múltiples mecánicos y roles' },
        { icon: '📊', text: 'Reportes por mes y por servicio' },
      ].map(f => (
        <div class="bg-[#13131a] border border-red-500/10 rounded-xl p-4 flex items-start gap-3">
          <span class="text-xl">{f.icon}</span>
          <span class="text-sm text-slate-300 leading-snug">{f.text}</span>
        </div>
      ))}
    </div>

    <!-- Para quién -->
    <div class="bg-[#13131a] border border-white/5 rounded-2xl p-6 mb-10 text-left">
      <p class="text-xs font-semibold text-red-400 uppercase tracking-widest mb-4">Para cualquier taller automotriz</p>
      <div class="flex flex-wrap gap-2">
        {['Talleres mecánicos', 'Chapistas', 'Electricistas automotor', 'Mecánicos independientes', 'Gomería', 'Lubricentros', 'Service de motos'].map(r => (
          <span class="text-xs px-3 py-1.5 rounded-full bg-red-500/10 border border-red-500/20 text-red-300">{r}</span>
        ))}
      </div>
    </div>

    <p class="text-slate-400 mb-6">¿Querés ser de los primeros en usarla? Anotate y te avisamos cuando esté lista.</p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/registro?app=taller"
        class="inline-flex items-center justify-center gap-2 bg-red-600 hover:bg-red-500 text-white font-semibold px-6 py-3.5 rounded-xl transition-colors">
        Anotarme en la lista
      </a>
      <a href={WA} target="_blank"
        class="inline-flex items-center justify-center gap-2 border border-white/10 hover:border-white/20 text-slate-300 hover:text-white font-semibold px-6 py-3.5 rounded-xl transition-colors">
        Consultar por WhatsApp
      </a>
    </div>

  </section>
</Layout>
