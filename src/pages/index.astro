</Layout>

<style>
  @keyframes letter-glow {
    0%   { opacity: 1; color: rgba(255,255,255,0.12); text-shadow: none; }
    40%  { opacity: 1; color: #fff; text-shadow: 0 0 18px rgba(255,255,255,0.9), 0 0 40px rgba(165,180,252,0.5); }
    100% { opacity: 1; color: #fff; text-shadow: none; }
  }
  @keyframes letter-glow-indigo {
    0%   { opacity: 1; color: rgba(99,102,241,0.12); text-shadow: none; }
    40%  { opacity: 1; color: #a5b4fc; text-shadow: 0 0 18px rgba(165,180,252,1), 0 0 40px rgba(99,102,241,0.7); }
    100% { opacity: 1; color: #818cf8; text-shadow: none; }
  }
  .hero-letter {
    display: inline-block;
    opacity: 0;
    animation: letter-glow 0.7s ease forwards;
  }
  .hero-letter-indigo {
    display: inline-block;
    opacity: 0;
    animation: letter-glow-indigo 0.7s ease forwards;
  }
</style>

<script>
  // Iluminación letra por letra del hero
  const line1El = document.querySelector('.hero-line-1');
  const line2El = document.querySelector('.hero-line-2');
  const text1 = 'La app que tu negocio';
  const text2 = 'estaba esperando';
  const BASE_DELAY = 80; // ms por letra

  if (line1El && line2El) {
    text1.split('').forEach((ch, i) => {
      const s = document.createElement('span');
      s.className = 'hero-letter';
      s.textContent = ch === ' ' ? ' ' : ch;
      s.style.animationDelay = `${i * BASE_DELAY}ms`;
      line1El.appendChild(s);
    });
    text2.split('').forEach((ch, i) => {
      const s = document.createElement('span');
      s.className = 'hero-letter-indigo';
      s.textContent = ch === ' ' ? ' ' : ch;
      s.style.animationDelay = `${(text1.length + i) * BASE_DELAY}ms`;
      line2El.appendChild(s);
    });
  }

  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = !answer.classList.contains('hidden');
      // Cerrar todos
      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(ic => ic.classList.remove('rotate-180'));
      // Abrir este si estaba cerrado
      if (!isOpen) {
        answer.classList.remove('hidden');
        icon.classList.add('rotate-180');
      }
    });
  });

  const form = document.getElementById('sugerencia-form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const rubro = (document.getElementById('rubro') as HTMLInputElement).value.trim();
    const problema = (document.getElementById('problema') as HTMLTextAreaElement).value.trim();
    const contacto = (document.getElementById('contacto-sug') as HTMLInputElement).value.trim();

    if (!rubro && !problema) return;

    const msg = `💡 *Nueva sugerencia de app*

*Rubro:* ${rubro || '(no indicó)'}
*Problema:* ${problema || '(no indicó)'}
*Contacto:* ${contacto || '(no dejó)'}`;

    window.open(`https://wa.me/542235767784?text=${encodeURIComponent(msg)}`, '_blank');
  });
</script>
