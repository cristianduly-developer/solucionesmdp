  <!-- CTA final -->
  <section class="max-w-6xl mx-auto px-4 py-24 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">¿No sabés por dónde empezar?</h2>
    <p class="text-slate-400 text-lg mb-8 max-w-xl mx-auto">
      Contanos qué hace tu negocio y te recomendamos la app que más te sirve — sin compromiso.
    </p>
    <a href="/registro"
      class="inline-flex items-center gap-3 bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-8 py-4 rounded-xl transition-colors text-lg">
