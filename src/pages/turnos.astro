---
import Layout from '../layouts/Layout.astro';
import AppPage from '../components/AppPage.astro';
---
<Layout title="App Turnos" description="Agenda online para turnos y reservas. Reservas 24/7, link propio y gestión de clientes desde el celular.">
  <AppPage
    name="App Turnos"
    tagline="Agenda online para tu negocio"
    description="Reemplazá el cuaderno y los turnos por WhatsApp con una agenda digital inteligente. Tus clientes reservan solos, 24/7, desde el link de tu negocio — vos gestionás todo desde el celular."
    icon="📅"
    screenshots={['/screenshots/turnos/inicio.jpg', '/screenshots/turnos/agenda.jpg', '/screenshots/turnos/clientes.jpg', '/screenshots/turnos/reportes.jpg']}
    audience="Peluquerías · Barberías · Masajistas · Kinesiólogos · Spas · Nutricionistas · Psicólogos · Manicuras"
    accentColor="bg-emerald-600"
    accentBg="bg-emerald-500/10"
    accentBorder="border-emerald-500/30"
    accentText="text-emerald-400"
    ctaUrl="https://app-turnos-ochre.vercel.app"
    differentiators={[
      'Reservas online 24/7 sin app',
      'Link propio del negocio',
      'Sin registro para el cliente',
      'PWA instalable en el celular',
      'Notificaciones en tiempo real',
      'Señas para reducir ausencias',
      'Historial de clientes',
      'Mobile-first',
    ]}
    features={[
      { icon: '📅', title: 'Agenda visual', desc: 'Timeline diario y semanal por horas, calendario mensual con puntos indicadores. Sabés de un vistazo cómo tenés el día.' },
      { icon: '🔗', title: 'Link propio del negocio', desc: 'Cada negocio tiene su URL única (/r/tu-negocio) para compartir por WhatsApp, Instagram o bio. El cliente reserva en menos de 2 minutos, sin crear cuenta.' },
      { icon: '💰', title: 'Señas y cobros', desc: 'Configurá seña fija o porcentaje del servicio. Alias de transferencia integrado. Reducís ausencias y asegurás el turno.' },
      { icon: '👥', title: 'Múltiples profesionales', desc: 'Agregá profesionales con sus propios horarios, servicios y colores. Cada uno tiene su agenda independiente (plan Profesional+).' },
      { icon: '📋', title: 'Ficha por cliente', desc: 'Historial completo de visitas, notas de cada servicio (productos usados, alergias), lista negra y datos de contacto.' },
      { icon: '📊', title: 'Caja y reportes', desc: 'Recaudación del día, semana y mes. Turnos cobrados vs pendientes. Barra de progreso para ver cuántos turnos atendiste.' },
      { icon: '🛎️', title: 'Notificaciones push', desc: 'Recibís una notificación al instante cuando alguien reserva online. Sin necesidad de estar mirando la app.' },
      { icon: '⚙️', title: 'Onboarding en 3 pasos', desc: 'Nombre del negocio, datos personales y carga de servicios. En minutos estás listo para recibir turnos.' },
      { icon: '🚫', title: 'Cancelaciones con anticipación', desc: 'Definís cuántos días de anticipación mínima necesitás para que el cliente cancele o reprograme.' },
    ]}
    plans={[
      {
        name: 'Básico',
        features: [
          '1 agenda (profesional)',
          'Hasta 150 turnos por mes',
          'Link de reserva pública',
          'Gestión de clientes',
          'Señas con transferencia',
          'Historial de visitas',
        ],
      },
      {
        name: 'Profesional',
        highlight: true,
        badge: 'Más elegido',
        features: [
          'Hasta 3 agendas (profesionales)',
          'Turnos ilimitados',
          'Todo lo del plan Básico',
          'Personalización del link público',
          'Señas con MercadoPago (próximamente)',
          'Categorías de servicios',
        ],
      },
      {
        name: 'Premium',
        features: [
          'Agendas ilimitadas',
          'Turnos ilimitados',
          'Todo lo del plan Profesional',
          'Comisiones por profesional',
          'Ficha clínica avanzada',
          'Combos de servicios',
        ],
      },
    ]}
  />
</Layout>
