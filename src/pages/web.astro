---
import Layout from '../layouts/Layout.astro';

const WA = 'https://wa.me/542235767784';

const pasos = [
  { n: '01', icon: '💬', title: 'Nos contás qué necesitás', desc: 'Rubro, servicios, fotos que tenés y colores que te gustan. Por WhatsApp, sin formularios.' },
  { n: '02', icon: '🎨', title: 'Te armamos un boceto', desc: 'En 48 horas te mostramos el diseño. Lo ajustamos hasta que quede exactamente como querés.' },
  { n: '03', icon: '✅', title: 'Lo aprobás', desc: 'Revisás cada sección y nos confirmás cuando está listo para publicar.' },
  { n: '04', icon: '🚀', title: 'Lo publicamos', desc: 'Subimos todo y en minutos tu negocio tiene presencia online.' },
];

const tipos = [
  { icon: '💇', rubro: 'Estética y belleza', ejemplo: 'Galería de trabajos, servicios con precios y turno por WhatsApp.' },
  { icon: '🔧', rubro: 'Oficios y construcción', ejemplo: 'Portfolio de obras, zona de cobertura y formulario de presupuesto.' },
  { icon: '🍽️', rubro: 'Gastronomía', ejemplo: 'Carta digital, horarios, local en mapa y reserva online.' },
  { icon: '📚', rubro: 'Profesionales', ejemplo: 'Presentación, servicios, honorarios y formulario de consulta.' },
  { icon: '🏪', rubro: 'Comercios', ejemplo: 'Catálogo de productos con precios y link directo a WhatsApp.' },
  { icon: '🏟️', rubro: 'Espacios y eventos', ejemplo: 'Galería, disponibilidad, precios por temporada y reserva.' },
];
---

<Layout
  title="Web para tu negocio"
  description="Diseñamos y publicamos el sitio de tu negocio en menos de una semana. Landing page profesional, dominio .com.ar y hosting incluido."
>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 pt-20 pb-16">
    <div class="flex flex-col md:flex-row gap-12 items-center">
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 bg-violet-500/10 border border-violet-500/20 text-violet-400 text-sm px-4 py-1.5 rounded-full mb-6">
          <span class="text-lg">🌐</span>
          Diseño web · A medida · Mar del Plata
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight leading-tight mb-4">
          Web para tu<br/>
          <span class="text-violet-400">negocio</span>
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed mb-8">
          Diseñamos y publicamos el sitio de tu negocio en menos de una semana.
          Con dominio .com.ar propio, optimizado para celular y listo para que Google te encuentre.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={WA} target="_blank"
            class="inline-flex items-center justify-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-6 py-3.5 rounded-xl transition-colors">
            Consultar por WhatsApp
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="#precios"
            class="inline-flex items-center justify-center gap-2 border border-white/10 hover:border-white/20 text-slate-300 hover:text-white font-semibold px-6 py-3.5 rounded-xl transition-colors">
            Ver precios
          </a>
        </div>
        <p class="text-sm text-slate-500 mt-4">Presupuesto sin cargo · Respuesta en el día</p>
      </div>

      <!-- Card lo que incluye -->
      <div class="flex-1">
        <div class="bg-[#13131a] border border-violet-500/20 rounded-2xl p-7 shadow-2xl shadow-violet-500/5">
          <p class="text-xs font-semibold text-violet-400 uppercase tracking-widest mb-5">Incluido en todos los planes</p>
          <ul class="flex flex-col gap-3.5">
            {[
              { icon: '🎨', text: 'Diseño a medida — nada de templates genéricos' },
              { icon: '📱', text: 'Mobile first — perfecto en celular y desktop' },
              { icon: '🌐', text: 'Dominio .com.ar — primer año incluido' },
              { icon: '🚀', text: 'Hosting y publicación — vos no hacés nada técnico' },
              { icon: '🔍', text: 'SEO básico — para que Google te encuentre' },
              { icon: '💬', text: 'WhatsApp flotante — contacto directo en toda la web' },
              { icon: '🔒', text: 'HTTPS — el candadito verde que da confianza' },
            ].map(item => (
              <li class="flex items-center gap-3">
                <span class="text-lg w-7 flex-shrink-0">{item.icon}</span>
                <span class="text-sm text-slate-300">{item.text}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 pt-5 border-t border-white/5 flex items-center justify-between">
            <div>
              <p class="text-xs text-slate-500">Entrega estimada</p>
              <p class="text-white font-semibold">5 a 7 días hábiles</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-slate-500">Presupuesto</p>
              <p class="text-violet-400 font-semibold">Sin cargo</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cómo trabajamos -->
  <section class="border-y border-white/5 bg-white/[0.02] py-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Cómo es el proceso</h2>
        <p class="text-slate-400">De cero a publicada en menos de una semana.</p>
      </div>
      <div class="relative">
        <div class="hidden md:block absolute top-10 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-transparent via-violet-500/30 to-transparent"></div>
        <div class="grid md:grid-cols-4 gap-5">
          {pasos.map(p => (
            <div class="bg-[#13131a] border border-white/5 rounded-2xl p-5 flex flex-col gap-3">
              <div class="flex items-center justify-between">
                <span class="text-2xl">{p.icon}</span>
                <span class="text-4xl font-black text-violet-400 opacity-20 leading-none">{p.n}</span>
              </div>
              <h3 class="font-bold text-white text-sm leading-snug">{p.title}</h3>
              <p class="text-slate-500 text-xs leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Para quién es -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Para cualquier tipo de negocio</h2>
      <p class="text-slate-400">Si tenés clientes, necesitás que te encuentren online.</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {tipos.map(t => (
        <div class="bg-[#13131a] border border-white/5 hover:border-violet-500/20 rounded-2xl p-5 transition-colors flex gap-4 items-start">
          <span class="text-2xl flex-shrink-0 mt-0.5">{t.icon}</span>
          <div>
            <h3 class="font-semibold text-white text-sm mb-1">{t.rubro}</h3>
            <p class="text-xs text-slate-400 leading-relaxed">{t.ejemplo}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Precios -->
  <section id="precios" class="border-t border-white/5 bg-white/[0.02] py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Precios</h2>
        <p class="text-slate-400">Precio fijo, sin sorpresas. Mantenimiento opcional.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            name: 'Landing básica',
            price: 'Desde $150.000',
            desc: 'Una página completa. Ideal para presentar tu negocio y que te contacten.',
            features: ['1 página larga', 'Diseño personalizado', 'Dominio .com.ar', 'Hosting 1 año', 'WhatsApp integrado', 'Formulario de contacto'],
            highlight: false,
          },
          {
            name: 'Sitio completo',
            price: 'Desde $280.000',
            desc: 'Varias secciones o páginas. Portfolio, galería, testimonios y contacto.',
            features: ['Hasta 5 páginas', 'Todo lo de Landing', 'Galería de fotos', 'Sección de testimonios', 'Blog o novedades', 'SEO avanzado'],
            highlight: true,
            badge: 'Más elegido',
          },
          {
            name: 'Mantenimiento',
            price: 'Desde $30.000/mes',
            desc: 'Actualizaciones de fotos, precios, textos o nuevas secciones cuando lo necesitás.',
            features: ['Cambios ilimitados', 'Actualización de contenido', 'Renovación del hosting', 'Soporte técnico', 'Copias de seguridad', 'Asesoramiento mensual'],
            highlight: false,
          },
        ].map(plan => (
          <div class={`relative bg-[#13131a] rounded-2xl p-6 border ${plan.highlight ? 'border-violet-500/40' : 'border-white/5'}`}>
            {plan.badge && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 text-xs font-semibold px-3 py-1 rounded-full bg-violet-600 text-white whitespace-nowrap">
                {plan.badge}
              </div>
            )}
            <h3 class="font-bold text-white text-xl mb-1">{plan.name}</h3>
            <p class="text-violet-400 font-semibold text-lg mb-2">{plan.price}</p>
            <p class="text-slate-500 text-sm mb-5 leading-relaxed">{plan.desc}</p>
            <ul class="space-y-2.5">
              {plan.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-slate-400">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={WA} target="_blank"
              class={`mt-7 block text-center font-semibold py-3 rounded-xl text-sm transition-colors ${plan.highlight ? 'bg-violet-600 hover:bg-violet-500 text-white' : 'border border-white/10 text-slate-300 hover:border-white/20 hover:text-white'}`}>
              Consultar precio exacto →
            </a>
          </div>
        ))}
      </div>
      <p class="text-center text-slate-500 text-sm mt-8">
        ¿Necesitás algo diferente?
        <a href={WA} target="_blank" class="text-slate-400 hover:text-white underline ml-1">Hablamos y lo armamos a medida</a>
      </p>
    </div>
  </section>

  <!-- CTA final -->
  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">¿Arrancamos?</h2>
    <p class="text-slate-400 text-lg mb-8">
      Contanos qué necesitás y en el día te mandamos un presupuesto sin cargo.
    </p>
    <a href={WA} target="_blank"
      class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-8 py-4 rounded-xl transition-colors text-lg">
      Consultar por WhatsApp
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </section>

</Layout>
