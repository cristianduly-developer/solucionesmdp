---
import '../styles/global.css';
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Soluciones MDP — Próximamente</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#0a0a0f] text-slate-100 font-['Inter',sans-serif] antialiased min-h-screen flex items-center justify-center">
    <div class="text-center px-6 max-w-lg mx-auto">
      <img src="/logo.png" alt="Soluciones MDP" class="h-24 w-auto mx-auto mb-10" />
      <h1 class="text-3xl font-bold text-white mb-4">Estamos trabajando en algo nuevo</h1>
      <p class="text-slate-400 text-lg mb-10 leading-relaxed">
        Muy pronto vas a poder conocer todas nuestras apps para negocios argentinos.
      </p>
      <a
        href="https://wa.me/542235767784"
        target="_blank"
        class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium px-6 py-3 rounded-xl transition-colors text-sm"
      >
        Contactanos por WhatsApp
      </a>
    </div>
  </body>
</html>
