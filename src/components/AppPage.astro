---
interface Feature {
  title: string;
  desc: string;
  icon: string;
}

interface Plan {
  name: string;
  highlight?: boolean;
  badge?: string;
  price?: string;
  features: string[];
}

interface Props {
  name: string;
  tagline: string;
  description: string;
  icon: string;
  screenshots: string[];
  accentColor: string;
  accentBg: string;
  accentBorder: string;
  accentText: string;
  ctaUrl: string;
  features: Feature[];
  plans: Plan[];
  audience: string;
  differentiators: string[];
}

const {
  name, tagline, description, icon, screenshots,
  accentColor, accentBg, accentBorder, accentText,
  ctaUrl, features, plans, audience, differentiators
} = Astro.props;

const carouselId = `carousel-${name.replace(/\s/g, '-').toLowerCase()}`;
---

<!-- Hero -->
<section class="max-w-6xl mx-auto px-4 pt-20 pb-16">
  <div class="flex flex-col md:flex-row gap-12 items-center">
    <div class="flex-1">
      <div class={`inline-flex items-center gap-2 ${accentBg} border ${accentBorder} ${accentText} text-sm px-4 py-1.5 rounded-full mb-6`}>
        <span class="text-lg">{icon}</span>
        {audience}
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight leading-tight mb-4">
        {name}
      </h1>
      <p class={`text-xl font-medium mb-4 ${accentText}`}>{tagline}</p>
      <p class="text-slate-400 text-lg leading-relaxed mb-8">{description}</p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={ctaUrl} target="_blank"
          class={`inline-flex items-center justify-center gap-2 ${accentColor} text-white font-semibold px-6 py-3.5 rounded-xl transition-opacity hover:opacity-90`}>
          Probar 28 días gratis
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="https://wa.me/542235767784" target="_blank"
          class="inline-flex items-center justify-center gap-2 border border-white/10 hover:border-white/20 text-slate-300 hover:text-white font-semibold px-6 py-3.5 rounded-xl transition-colors">
          Consultar por WhatsApp
        </a>
      </div>
      <p class="text-sm text-slate-500 mt-4">Sin tarjeta de crédito · Hasta 28 días gratis</p>
    </div>

    <!-- Carrusel sliding -->
    <div class="flex-1 flex flex-col items-center gap-4">
      <div class="relative w-56 md:w-64 overflow-hidden rounded-3xl shadow-2xl border border-white/10" id={carouselId}>
        <div class="flex transition-transform duration-700 ease-in-out" data-track>
          {screenshots.map((src, i) => (
            <img
              src={src}
              alt={`${name} pantalla ${i + 1}`}
              class="w-full flex-shrink-0 object-cover"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ))}
        </div>
      </div>
      <!-- Dots -->
      <div class="flex gap-2" data-dots={carouselId}>
        {screenshots.map((_, i) => (
          <button
            class={`transition-all duration-300 rounded-full ${i === 0 ? `w-5 h-2 ${accentColor}` : 'w-2 h-2 bg-white/20'}`}
            data-dot={i}
            aria-label={`Pantalla ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Diferenciadores -->
<section class={`border-y ${accentBorder} ${accentBg} py-10`}>
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {differentiators.map(d => (
        <div class="flex items-start gap-2">
          <svg class={`w-5 h-5 mt-0.5 flex-shrink-0 ${accentText}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-sm text-slate-300">{d}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Features -->
<section class="max-w-6xl mx-auto px-4 py-24">
  <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-16">Todo lo que necesitás</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {features.map(f => (
      <div class="bg-[#13131a] border border-white/5 rounded-2xl p-6">
        <div class="text-3xl mb-4">{f.icon}</div>
        <h3 class="font-semibold text-white mb-2">{f.title}</h3>
        <p class="text-sm text-slate-400 leading-relaxed">{f.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- Planes -->
<section class="border-t border-white/5 bg-white/[0.02] py-24">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Planes</h2>
      <p class="text-slate-400 text-lg">Comenzá con el plan Profesional gratis por 28 días.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {plans.map(plan => (
        <div class={`relative bg-[#13131a] rounded-2xl p-6 border transition-all ${plan.highlight ? `${accentBorder}` : 'border-white/5'}`}>
          {plan.badge && (
            <div class={`absolute -top-3 left-1/2 -translate-x-1/2 text-xs font-semibold px-3 py-1 rounded-full ${accentColor} text-white whitespace-nowrap`}>
              {plan.badge}
            </div>
          )}
          <h3 class="font-bold text-white text-xl mb-1">{plan.name}</h3>
          {plan.price
            ? <p class={`text-lg font-bold mb-1 ${plan.highlight ? accentText : 'text-slate-300'}`}>{plan.price}</p>
            : null
          }
          {plan.highlight
            ? <p class={`text-sm font-semibold mb-6 ${accentText}`}>28 días gratis, sin tarjeta</p>
            : <p class="text-sm text-slate-500 mb-6">{plan.price ? 'Consultá disponibilidad' : 'Consultá precio'}</p>
          }
          <ul class="space-y-3">
            {plan.features.map(feat => (
              <li class="flex items-start gap-2 text-sm text-slate-400">
                <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${accentText}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {feat}
              </li>
            ))}
          </ul>
          {plan.highlight
            ? (
              <a href={ctaUrl} target="_blank"
                class={`mt-8 block text-center font-semibold py-3 rounded-xl transition-all text-sm ${accentColor} text-white hover:opacity-90`}>
                Empezar gratis ahora →
              </a>
            ) : (
              <a href="https://wa.me/542235767784" target="_blank"
                class="mt-8 block text-center font-semibold py-3 rounded-xl transition-all text-sm border border-white/10 text-slate-300 hover:border-white/20 hover:text-white">
                Consultar por WhatsApp
              </a>
            )
          }
        </div>
      ))}
    </div>
    <p class="text-center text-slate-500 text-sm mt-8">
      ¿No sabés qué plan necesitás?
      <a href="https://wa.me/542235767784" target="_blank" class="text-slate-400 hover:text-white underline ml-1">Escribinos</a>
    </p>
  </div>
</section>

<!-- CTA final -->
<section class="max-w-6xl mx-auto px-4 py-24 text-center">
  <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Empezá hoy, sin compromisos</h2>
  <p class="text-slate-400 text-lg mb-8 max-w-xl mx-auto">
    28 días gratis con el plan Profesional completo. Sin tarjeta, sin instalación.
  </p>
  <a href="/registro"
    class={`inline-flex items-center gap-2 ${accentColor} text-white font-semibold px-8 py-4 rounded-xl transition-opacity hover:opacity-90 text-lg`}>
    Probar gratis ahora
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</section>

<script define:vars={{ carouselId }}>
  const wrap = document.getElementById(carouselId);
  if (wrap) {
    const track = wrap.querySelector('[data-track]');
    const dotsWrap = document.querySelector(`[data-dots="${carouselId}"]`);
    const dots = dotsWrap ? dotsWrap.querySelectorAll('[data-dot]') : [];
    const total = track ? track.children.length : 0;
    let current = 0;

    function goTo(n) {
      current = (n + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        if (i === current) {
          d.classList.add('w-5', 'h-2');
          d.classList.remove('w-2', 'h-2', 'bg-white/20');
        } else {
          d.classList.remove('w-5');
          d.classList.add('w-2', 'bg-white/20');
        }
      });
    }

    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
    setInterval(() => goTo(current + 1), 2500);
  }
</script>
